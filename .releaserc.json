{
  "branches": [
    "main"
  ],
  "tagFormat": "v${version}",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "echo ${nextRelease.version} > .version && npm version ${nextRelease.version} --allow-same-version --no-git-tag-version",
        "publishCmd": "bun run package:release"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          {
            "path": "dist/webxdc-svelte-shadcn-template_v*.xdc",
            "label": "Webxdc Svelte Template (${nextRelease.version})"
          },
          {
            "path": "dist/webxdc-svelte-shadcn-template_v*.zip",
            "label": "Webxdc Svelte Template Zip (${nextRelease.version})"
          }
        ]
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "package.json",
          "CHANGELOG.md",
          ".version"
        ],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ]
  ]
}
